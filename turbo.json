{
    "$schema": "https://turbo.build/schema.json",
    "tasks": {
        "dev": {
            "cache": false,
            "persistent": true
        },
        "build": {
            "dependsOn": ["^build", "prisma:generate"],
            "outputs": [
                "src/generated/**",
                "prisma/dev.db",
                ".vercel/output/**"
            ]
        },
        "prisma:generate": {
            "cache": false
        }
    }
}
